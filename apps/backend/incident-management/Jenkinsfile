pipeline {
    agent any

    environment {
        SERVICE_NAME  = 'incident-management'
        SERVICE_DIR   = 'apps/backend/incident-management'
        SONAR_PROJECT = 'smartsite-incident-management'
        DOCKER_IMAGE  = 'smart-site-incident-management'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code récupéré depuis GitHub"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm ci'
                    echo "✅ Dépendances installées"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm test -- --coverage --coverageReporters=lcov --forceExit || echo "⚠️ Pas de tests configurés"'
                    echo "✅ Tests unitaires terminés"
                }
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm run build'
                    echo "✅ Build terminé"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        withEnv(["PATH+SONAR=${tool 'SonarQubeScanner'}/bin"]) {
                            sh """
                                sonar-scanner \
                                    -Dsonar.projectKey=${SONAR_PROJECT} \
                                    -Dsonar.projectName='SmartSite - Incident Management' \
                                    -Dsonar.sources=src \
                                    -Dsonar.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/** \
                                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                    -Dsonar.coverage.exclusions=**/*.spec.ts,**/node_modules/**,**/dist/**
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo "🐳 Construction image ${DOCKER_IMAGE}..."
                dir("${SERVICE_DIR}") {
                    sh '''
                        docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                        docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                        echo "✅ Image Docker construite"
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo "☸️ Déploiement ${SERVICE_NAME} sur Kubernetes..."
                sh '''
                    kubectl create namespace smart-site 2>/dev/null || true

                    kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: incident-management
  namespace: smart-site
spec:
  replicas: 2
  selector:
    matchLabels:
      app: incident-management
  template:
    metadata:
      labels:
        app: incident-management
    spec:
      containers:
      - name: incident-management
        image: ${DOCKER_IMAGE}:${BUILD_NUMBER}
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 3004
        env:
        - name: PORT
          value: "3004"
        livenessProbe:
          httpGet:
            path: /health
            port: 3004
          initialDelaySeconds: 30
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: incident-management
  namespace: smart-site
spec:
  selector:
    app: incident-management
  ports:
    - port: 80
      targetPort: 3004
      protocol: TCP
  type: ClusterIP
EOF

                    echo "✅ Déploiement incident-management terminé"
                '''
            }
        }
    }

    post {
        success {
            echo "🎉 CI/CD réussi pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        failure {
            echo "❌ CI/CD échoué pour ${SERVICE_NAME} — build #${BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}
