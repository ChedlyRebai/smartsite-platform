GESTION_SITE_URL=http://localhost:3001/api
PAYMENT_API_URL=http://localhost:3008/api/payments
STRIPE_API_URL=http://localhost:3008/api/payments/stripe/create-payment-intent

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://localhost:3001

# Email Configuration (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=materials-service@smartsite.com
ADMIN_EMAIL=admin@example.com
FRONTEND_LOGIN_URL=http://localhost:5173/login

# Legacy email variables (kept for backward compatibility)
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-password
