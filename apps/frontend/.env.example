# URL de l’API Nest **user-authentication** — doit être la même que PORT ci‑dessous côté backend.
# Défaut backend : PORT=3000 → http://localhost:3000
VITE_AUTH_API_URL=http://localhost:3000

# API gestion des chantiers (Nest gestion-site, préfixe /api inclus) — PORT backend défaut 3001
VITE_GESTION_SITE_URL=http://localhost:3001/api

# Planification / jalons (gestion-planing), PORT 3002
VITE_PLANNING_URL=http://localhost:3002

# Incidents (incident-management), PORT 3003
VITE_INCIDENT_URL=http://localhost:3003

# Autres microservices (optionnel)
# VITE_NOTIFICATION_URL=http://localhost:3004/notification

# Stream Video/Chat public API key (required for messaging and video call pages)
# Example: VITE_STREAM_API_KEY=gcatxrhb47wf
# VITE_STREAM_API_KEY=
