{
  "info": {
    "name": "Feature Team Assignment API",
    "description": "API pour la gestion des équipes sur les sites - Postman Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "baseUrlSite",
      "value": "http://localhost:3001/api"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. ROLES - Créer d'abord",
      "item": [
        {
          "name": "Create Role - admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/roles",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"admin\",\n  \"description\": \"Administrateur système\"\n}"
            }
          }
        },
        {
          "name": "Create Role - manager",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/roles",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"manager\",\n  \"description\": \"Gestionnaire de chantier\"\n}"
            }
          }
        },
        {
          "name": "Create Role - chef_equipe",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/roles",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"chef_equipe\",\n  \"description\": \"Chef d'équipe\"\n}"
            }
          }
        },
        {
          "name": "Create Role - worker",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/roles",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"worker\",\n  \"description\": \"Ouvrier\"\n}"
            }
          }
        },
        {
          "name": "Create Role - client",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/roles",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"client\",\n  \"description\": \"Client\"\n}"
            }
          }
        },
        {
          "name": "Get All Roles (pour voir les IDs)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/roles",
            "header": []
          }
        }
      ]
    },
    {
      "name": "2. AUTHENTICATION",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cin\": \"12345678\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. USERS",
      "item": [
        {
          "name": "Create User (AVEC NOM DU ROLE)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cin\": \"98765432\",\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Ben Ali\",\n  \"email\": \"ahmed@example.com\",\n  \"phoneNumber\": \"+21698765432\",\n  \"address\": \"Tunis, Tunisia\",\n  \"departement\": \"Construction\",\n  \"role\": \"chef_equipe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": []
          }
        }
      ]
    },
    {
      "name": "4. SITES",
      "item": [
        {
          "name": "Create Site",
          "request": {
            "method": "POST",
            "url": "{{baseUrlSite}}/gestion-sites",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Chantier Tour Tunis\",\n  \"adresse\": \"Avenue Habib Bourguiba, Tunis\",\n  \"localisation\": \"Tunis\",\n  \"budget\": 5000000,\n  \"area\": 2500,\n  \"status\": \"planning\",\n  \"description\": \"Construction d'une tour\",\n  \"coordinates\": {\n    \"lat\": 36.8065,\n    \"lng\": 10.1815\n  }\n}"
            }
          }
        },
        {
          "name": "Get All Sites",
          "request": {
            "method": "GET",
            "url": "{{baseUrlSite}}/gestion-sites",
            "header": []
          }
        }
      ]
    },
    {
      "name": "5. TEAM ASSIGNMENT - SITES",
      "item": [
        {
          "name": "Assign Team to Site",
          "request": {
            "method": "POST",
            "url": "{{baseUrlSite}}/gestion-sites/SITE_ID/teams",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"USER_ID\"\n}"
            }
          }
        },
        {
          "name": "Get Teams Assigned to Site",
          "request": {
            "method": "GET",
            "url": "{{baseUrlSite}}/gestion-sites/SITE_ID/teams",
            "header": []
          }
        },
        {
          "name": "Remove Team from Site",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrlSite}}/gestion-sites/SITE_ID/teams/USER_ID",
            "header": []
          }
        },
        {
          "name": "Get All Sites with Teams",
          "request": {
            "method": "GET",
            "url": "{{baseUrlSite}}/gestion-sites/teams/all",
            "header": []
          }
        }
      ]
    },
    {
      "name": "6. TEAM ASSIGNMENT - USERS",
      "item": [
        {
          "name": "Assign Manager to User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/USER_ID/manager",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"managerId\": \"MANAGER_USER_ID\"\n}"
            }
          }
        },
        {
          "name": "Set User Responsibilities",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/USER_ID/responsibilities",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"responsibilities\": \"Chef d'équipe - Coordination des travaux\"\n}"
            }
          }
        },
        {
          "name": "Assign User to Site",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/USER_ID/site",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"siteId\": \"SITE_ID\"\n}"
            }
          }
        }
      ]
    }
  ]
}
